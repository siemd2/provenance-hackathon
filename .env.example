# Optional: enables Claude-authored anomaly explanations in the purchaser UI.
# Without it, the backend falls back to built-in template explanations (offline-safe).
# Copy to .env and fill in, then `docker compose up`.
ANTHROPIC_API_KEY=

# Unused by the app (it is stateless); defined only for harness / docker-compose compatibility.
DATABASE_URL=sqlite:///./provenance.db
